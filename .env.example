# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Replace ALL placeholder values with real ones
# 3. NEVER commit .env to git (it's in .gitignore for safety)
#
# WHY ENVIRONMENT VARIABLES?
# Secrets (passwords, API keys) must NOT be in source code because:
#   - Anyone with access to the repo can see them
#   - They're in git history forever (even if you delete them later)
#   - Different environments (dev/staging/production) need different values
#
# Environment variables are loaded at runtime by the dotenv package:
#   process.env.DB_PASSWORD → reads from .env file
# =============================================================================

# --- Server Configuration ---
NODE_ENV=production                          # 'production' enables secure cookies, CSP, etc.
PORT=3456                                    # port the Express server listens on
SESSION_SECRET=change-me-to-a-random-64-char-string  # used to sign session cookies — MUST be random and secret!

# --- Database (MariaDB) ---
DB_HOST=db                                   # "db" = the Docker Compose service name (internal DNS)
DB_PORT=3306                                 # MariaDB default port
DB_NAME=digital_family                       # database name (auto-created by MariaDB on first start)
DB_USER=digital_family                       # database username (auto-created by MariaDB)
DB_PASSWORD=change-me                        # database user password — use a strong random password!
DB_ROOT_PASSWORD=change-me-root              # MariaDB root password — even stronger!

# --- Email (SMTP) — for password reset emails and future notifications ---
SMTP_HOST=smtp.example.com                   # your email provider's SMTP server
SMTP_PORT=587                                # 587 = TLS (recommended), 465 = SSL, 25 = unencrypted
SMTP_USER=your-email@example.com             # SMTP login username
SMTP_PASS=your-email-password                # SMTP login password (or app-specific password)
SMTP_FROM=noreply@carbonnull.ch              # the "From" address on outgoing emails

# --- Cloudflare Tunnel (HTTPS access without port forwarding) ---
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token    # obtained from Cloudflare Zero Trust dashboard

# --- GitHub Webhook (auto-deploy on push to main) ---
GITHUB_WEBHOOK_SECRET=your-webhook-secret    # MUST match the secret configured in GitHub repo settings

# --- File Storage ---
UPLOAD_DIR=/app/uploads                      # path inside the Docker container (bind-mounted to NAS)
MAX_FILE_SIZE=26214400                       # max upload size in bytes (25 MB = 25 * 1024 * 1024)
